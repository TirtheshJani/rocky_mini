# Rocky Mini brain-server configuration.
# Copy real values to ~/.rocky_mini/.env (NOT into the repo).
# There are NO paid API keys anywhere in this project.

# Ollama OpenAI-compatible endpoint (the PC LAN brain server).
# In sim this is localhost; at hardware bring-up it is the PC's LAN IP.
ROCKY_LLM_BASE_URL=http://localhost:11434/v1

# Model tag. Toggle between the fine-tuned Rocky LoRA and stock Qwen for A/B.
#   rocky:latest            -> Qwen2.5-7B + Rocky LoRA (default once trained)
#   qwen2.5:7b-instruct     -> stock baseline
ROCKY_MODEL=qwen2.5:7b-instruct

# FastAPI /stt + /tts brain service (faster-whisper + Piper) on the PC.
ROCKY_SPEECH_BASE_URL=http://localhost:8123

# Optional LAN auth token shared between robot and brain server.
ROCKY_LAN_TOKEN=

# Audio backend: "reachy" (mini.media on hardware) or "sounddevice" (PC dev).
ROCKY_AUDIO_BACKEND=sounddevice
